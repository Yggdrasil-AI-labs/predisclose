#!/usr/bin/env bash
# predisclose pre-commit hook. Blocks a commit that introduces a leak.
# Install:  ln -sf ../../hooks/pre-commit .git/hooks/pre-commit
#   (or copy it; or use `pre-commit` framework via .pre-commit-config.yaml)
#
# Honors a private rules file automatically: .predisclose.local.json at the repo
# root, or $PREDISCLOSE_RULES. Override the blocking threshold with PREDISCLOSE_FAIL_ON.
set -euo pipefail

FAIL_ON="${PREDISCLOSE_FAIL_ON:-medium}"

if command -v predisclose >/dev/null 2>&1; then
  RUN=(predisclose)
else
  RUN=(python3 -m predisclose)
fi

if ! "${RUN[@]}" scan --staged --fail-on "$FAIL_ON"; then
  echo ""
  echo "predisclose blocked this commit (findings at/above '$FAIL_ON')."
  echo "Fix the lines above, or if a match is a false positive add it to the"
  echo "'allow' list in your private rules file. To bypass once: git commit --no-verify"
  exit 1
fi
